\PYG{c+c1}{\PYGZsh{} Calculate the total sales from food items (not including drinks i.e., Soda)}
\PYG{n}{total\PYGZus{}food\PYGZus{}sales} \PYG{o}{=} \PYG{n}{df}\PYG{p}{[}
    \PYG{p}{[}\PYG{l+s+s1}{\PYGZsq{}Burgers\PYGZsq{}}\PYG{p}{,} \PYG{l+s+s1}{\PYGZsq{}Hot Dogs\PYGZsq{}}\PYG{p}{,} \PYG{l+s+s1}{\PYGZsq{}Salads\PYGZsq{}}\PYG{p}{,} \PYG{l+s+s1}{\PYGZsq{}Fries\PYGZsq{}}\PYG{p}{,} \PYG{l+s+s1}{\PYGZsq{}Ice Cream\PYGZsq{}}\PYG{p}{]}
\PYG{p}{]}\PYG{o}{.}\PYG{n}{sum}\PYG{p}{()}\PYG{o}{.}\PYG{n}{sum}\PYG{p}{()}

\PYG{c+c1}{\PYGZsh{} Format the result to USD, with a dollar sign and two decimal places}
\PYG{n}{total\PYGZus{}food\PYGZus{}sales\PYGZus{}formatted} \PYG{o}{=} \PYG{l+s+sa}{f}\PYG{l+s+s2}{\PYGZdq{}\PYGZdl{}}\PYG{l+s+si}{\PYGZob{}}\PYG{n}{total\PYGZus{}food\PYGZus{}sales}\PYG{l+s+si}{:}\PYG{l+s+s2}{,.2f}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{\PYGZdq{}}
\end{Verbatim}
